{
  "name": "listarr",
  "version": "1.0.0",
  "description": "A self-hosted, real-time shopping list app",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "start": "npm run start -w frontend",
    "build": "npm run build -w frontend",
    "preview": "npm run preview -w frontend",
    "lint": "npm run lint -w frontend",
    "typecheck": "npm run typecheck -w frontend",
    "test": "npm run test -w frontend",
    "test:coverage": "npm run test:coverage -w frontend",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.5.4"
  }
}
